{
  "manifest_version": 3,
  "name": "Taleos",
  "version": "1.0.41",
  "description": "Automatisation de candidatures bancaires - Taleos",
  "permissions": [
    "activeTab",
    "alarms",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://taleos.co/*",
    "https://*.taleos.co/*",
    "https://*.firebaseapp.com/*",
    "https://*.googleapis.com/*",
    "https://firestore.googleapis.com/*",
    "https://firebasestorage.googleapis.com/*",
    "https://*.firebasestorage.app/*",
    "https://groupecreditagricole.jobs/*",
    "https://careers.societegenerale.com/*",
    "https://socgen.taleo.net/*",
    "https://*.deloitte.com/*",
    "https://*.myworkdayjobs.com/*",
    "http://localhost/*",
    "http://localhost:8000/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:8000/*",
    "https://*.github.io/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://taleos.co/*",
        "https://*.taleos.co/*",
        "http://localhost/*",
        "http://localhost:8000/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:8000/*",
        "https://*.github.io/*"
      ],
      "js": [
        "content/taleos-injector.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://groupecreditagricole.jobs/*"
      ],
      "js": [
        "content/ca-connexion-filler.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://careers.societegenerale.com/*"
      ],
      "js": [
        "content/sg-careers-helper.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://socgen.taleo.net/*"
      ],
      "js": [
        "content/sg-at-click-polyfill.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://socgen.taleo.net/*"
      ],
      "js": [
        "content/sg-taleo-runner.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.myworkdayjobs.com/*",
        "https://www.deloitte.com/*",
        "https://*.deloitte.com/*"
      ],
      "js": [
        "content/deloitte-careers-filler.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}