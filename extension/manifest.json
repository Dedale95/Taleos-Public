{
  "manifest_version": 3,
  "name": "Taleos",
  "version": "1.0.0",
  "description": "Automatisation de candidatures bancaires - Taleos",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.taleos.co/*",
    "https://*.firebaseapp.com/*",
    "https://*.googleapis.com/*",
    "https://firestore.googleapis.com/*",
    "https://firebasestorage.googleapis.com/*",
    "https://*.firebasestorage.app/*",
    "https://groupecreditagricole.jobs/*",
    "https://careers.societegenerale.com/*",
    "https://*.deloitte.com/*",
    "http://localhost/*",
    "https://*.github.io/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.taleos.co/*",
        "http://localhost/*",
        "https://*.github.io/*"
      ],
      "js": ["content/taleos-injector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
